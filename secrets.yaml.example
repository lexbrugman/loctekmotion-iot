# Copy this file to secrets.yaml and fill in your own values.
# secrets.yaml is git-ignored so your credentials never get committed.
# For CI builds, set these as GitHub repository secrets instead (see README).

wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"
ap_fallback_password: "your_ap_fallback_password"

# Home Assistant API encryption key. Generate a new one at:
# https://esphome.io/components/api.html  (or `openssl rand -base64 32`)
api_encryption_key: "iOZqtvw31Yy6sasRl5h2DElG2VDlqW2WjJEKObVN8bg="
